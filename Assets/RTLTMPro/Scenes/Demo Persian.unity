  originalText: "\u0633\u062A\u0627\u06CC\u0634 \u062E\u062F\u0627\u0648\u0646\u062F\u06CC
    \u0631\u0627 \u06A9\u0647 \u062F\u0631 \u06CC\u06AF\u0627\u0646\u06AF\u06CC\u060C
    \u0648\u0627\u0644\u0627 \u0648 \u062F\u0631 \u0628\u06CC\xAD \u0647\u0645\u062A\u0627\u06CC\u06CC\u060C
    \u0646\u0632\u062F\u06CC\u06A9 \u0648 \u062F\u0631 \u0627\u0642\u062A\u062F\u0627\u0631
    \u0634\u06A9\u0648\u0647\u0645\u0646\u062F\u060C \u0648 \u062F\u0631 \u0627\u0631\u06A9\u0627\u0646
    \u062E\u0648\u062F \u0628\u0633\u06CC \u0628\u0632\u0631\u06AF \u0627\u0633\u062A.
    \u062F\u0627\u0646\u0634\u0634 \u0628\u0631 \u0647\u0645\u0647 \u0686\u06CC\u0632
    \u0627\u062D\u0627\u0637\u0647 \u062F\u0627\u0631\u062F \u0648 \u062D\u0627\u0644
    \u0622\u0646\u06A9\u0647 \u0627\u0648 \u062F\u0631 \u0645\u0642\u0627\u0645 \u062E\u0648\u062F\u0634
    \u0627\u0633\u062A \u0648 \u0622\u0641\u0631\u06CC\u062F\u06AF\u0627\u0646\u060C
    \u0647\u0645\u06AF\u06CC \u0645\u0642\u0647\u0648\u0631 \u0642\u062F\u0631\u062A
    \u0627\u0648\u06CC\u0646\u062F. \u0628\u0632\u0631\u06AF\u06CC \u06A9\u0647 \u067E\u06CC\u0648\u0633\u062A\u0647
    \u0628\u0648\u062F\u0647 \u0648 \u0633\u062A\u0648\u062F\u0647 \xAD\u0627\u06CC
    \u06A9\u0647 \u0647\u0645\u06CC\u0634\u0647 \u062E\u0648\u0627\u0647\u062F \u0628\u0648\u062F.
    \u067E\u062F\u06CC\u062F \u0622\u0648\u0631\u0646\u062F\u0647 \u0622\u0633\u0645\u0627\u0646\u0647\u0627\u06CC
    \u0628\u0644\u0646\u062F \u0648 \u06AF\u0633\u062A\u0631\u0627\u0646\u0646\u062F\u0647
    \u06AF\u0633\u062A\u0631\u0647 \u0634\u062F\u0647 \xAD\u0647\u0627 \u0648 \u0641\u0631\u0645\u0627\u0646\u0631\u0648\u0627\u06CC
    \u0645\u0637\u0644\u0642 \u0632\u0645\u06CC\u0646\u0647\u0627 \u0648 \u0622\u0633\u0645\u0627\u0646\u0647\u0627\u0633\u062A
    \u0648 \u0628\u06CC\xAD \u0627\u0646\u062F\u0627\u0632\u0647 \u067E\u0627\u06A9
    \u0648 \u0628\u06CC\u0646\u0647\u0627\u06CC\u062A \u067E\u0627\u06A9\u06CC\u0632\u0647
    \u0627\u0633\u062A. \u067E\u0631\u0648\u0631\u062F\u06AF\u0627\u0631 \u0641\u0631\u0634\u062A\u06AF\u0627\u0646
    \u0648 \u0631\u0648\u062D \xAD\u0627\u0644\u0642\u062F\u0633 \u0648 \u0646\u0633\u0628\u062A
    \u0628\u0647 \u0647\u0631 \u0622\u0646\u0686\u0647 \u0622\u0641\u0631\u06CC\u062F\u0647\u060C
    \u0641\u0632\u0648\u0646\u0628\u062E\u0634 \u0627\u0633\u062A \u0648 \u0686\u0647
    \u0633\u0627\u062E\u062A\u0647 \u0648 \u067E\u0631\u062F\u0627\u062E\u062A\u0647\u060C
    \u063A\u0631\u0642\u0647 \u0639\u0637\u0627 \u0648 \u0641\u0636\u0644 \u0627\u0648\u06CC\u0646\u062F.
    \u0647\u0631 \u062F\u06CC\u062F\u0647\xAD \u0627\u06CC \u0631\u0627 \u0645\u06CC\xAD
    \u0628\u06CC\u0646\u062F\u060C \u0648 \u0647\u06CC\u0686 \u062F\u06CC\u062F\u0647
    \xAD\u0627\u06CC \u0631\u0627 \u062A\u0648\u0627\u0646 \u062F\u06CC\u062F\u0627\u0631
    \u0627\u0648 \u0646\u06CC\u0633\u062A."
